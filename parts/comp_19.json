        "type": "VCC"
      },
      {
        "name": "GND",
        "offsetY": 30,
        "type": "GND"
      },
      {
        "name": "CS",
        "offsetY": 45,
        "type": "GPIO"
      },
      {
        "name": "RST",
        "offsetY": 60,
        "type": "GPIO"
      },
      {
        "name": "DC",
        "offsetY": 75,
        "type": "GPIO"
      },
      {
        "name": "MOSI",
        "offsetY": 90,
        "type": "SPI_MOSI"
      },
      {
        "name": "SCK",
        "offsetY": 105,
        "type": "SPI_SCK"
      }
    ]
